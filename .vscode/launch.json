{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Watch RegistrationWebApp",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5012", // Check launchSettings.json for correct URL/Port
            "runtimeExecutable": "stable", // or "canary", "beta", "path to chrome/edge executable"
            "internalConsoleOptions": "neverOpen",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Application started. Press Ctrl+C to shut down.",
                "uriFormat": "http://localhost:5012"
            },
            "preLaunchTask": "Dotnet Watch RegistrationWebApp",
            "presentation": {
                "hidden": false,
                "group": "Hot Reload",
                "order": 1
            }
        },
        {
            "name": "Attach Blazor Debug Proxy",
            "type": "blazorwasm",
            "request": "attach",
            "timeout": 60000,
            "internalConsoleOptions": "neverOpen",
            "url": "http://localhost:5012", // Must match the URL in the other config
            "presentation": {
                "hidden": true,
                "group": "Hot Reload",
                "order": 1
            }
        },
        {
            //This is helpful for debugging with breakpoints.
            "name": "Debug RegistrationWebApp",
            "type": "coreclr",
            "request": "launch",
            "program": "/bin/Debug/net10.0/RegistrationWebApp.dll",
            "console": "integratedTerminal",
            "requireExactSource": true,
            "cwd":"${workspaceFolder}/RegistrationWebApp",
            "preLaunchTask": "Build WebApp",
            // Launches the app in your default browser when the API is ready.
            "serverReadyAction":{
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)",
                "killOnServerStop": true
            },
        },
        {
            "name": "Debug RegistrationWebAPI",
            "type": "coreclr",
            "request": "launch",
            "program": "/bin/Debug/net10.0/RegistrationWebAPI.dll",
            "console": "integratedTerminal",
            "requireExactSource": true,
            "cwd":"${workspaceFolder}/RegistrationWebAPI",
            "preLaunchTask": "Build WebApi",
            // Opens the Swagger UI in the browser when the API is ready. 
            "serverReadyAction":{
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)",
                "uriFormat": "%s/swagger",
                "killOnServerStop": true
            }
        },
        {
            "name": "Debug RegistrationWebApp after WebApi",
            "type": "coreclr",
            "request": "launch",
            "program": "/bin/Debug/net10.0/RegistrationWebApp.dll",
            "console": "integratedTerminal",
            "requireExactSource": true,
            "cwd":"${workspaceFolder}/RegistrationWebApp",
            "preLaunchTask": "Build All Projects",
        }

    ],       
    "compounds": [
        {
            "name": "RegistrationWebApp: Debug (Hot Reload)",
            "configurations": [ "Watch RegistrationWebApp", "Attach Blazor Debug Proxy"],
            "stopAll": true,    
            "presentation": {
                "hidden": false,
                "group": "Hot Reload",
                "order": 1
            }       
        },
        {
            "name": "Debug WebAPI & WebApp",
            "configurations": [ "Debug RegistrationWebAPI", "Debug RegistrationWebApp"],
            "stopAll": true, 
            "preLaunchTask": "Build All Projects",
            "presentation": {
                "hidden": false,
                "group": "Dual Debug Configurations",
                "order": 1
            }
        }
    ]
}
