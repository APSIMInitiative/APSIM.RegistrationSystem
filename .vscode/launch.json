{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Watch RegistrationWebApp",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5012", // Check launchSettings.json for correct URL/Port
            "runtimeExecutable": "stable", // or "canary", "beta", "path to chrome/edge executable"
            "internalConsoleOptions": "neverOpen",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Application started. Press Ctrl+C to shut down.",
                "uriFormat": "http://localhost:5012"
            },
            "preLaunchTask": "dotnet watch run",
        },
        {
            "name": "Attach Blazor Debug Proxy",
            "type": "blazorwasm",
            "request": "attach",
            "timeout": 60000,
            "internalConsoleOptions": "neverOpen",
            "url": "http://localhost:5012", // Must match the URL in the other config
        },
        {
            //This is helpful for debugging with breakpoints.
            "name": "Debug RegistrationWebApp",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build",
            "program": "/bin/Debug/net10.0/RegistrationWebApp.dll",
            "args": [],
            "console": "integratedTerminal",
            "requireExactSource": true,
            "cwd":"${workspaceFolder}/RegistrationWebApp"
        }
    ],       
    "compounds": [
        {
            "name": "Run & Debug with Hot Reload",
            "configurations": [ "Watch RegistrationWebApp", "Attach Blazor Debug Proxy"],
            "stopAll": true,
            
        }
    ]
}
