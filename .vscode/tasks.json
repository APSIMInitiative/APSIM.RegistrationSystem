{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet watch run",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "RegistrationWebApp.csproj"
            ],
            "problemMatcher": "$msCompile",
            "isBackground": true,
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}/RegistrationWebApp"
            }
        },
        {
            "label": "just watch RegistrationWebApp",
            "type": "dotnet",
            "task": "watch RegistrationWebApp",
            "file": "RegistrationWebApp.csproj",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/RegistrationWebApp"
            }
        },
        {
            "label": "dotnet: build RegistrationWebApp",
            "type": "dotnet",
            "task": "build",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/RegistrationWebApp"
            }
        },
        {
            "label": "dotnet: build RegistrationWebAPI",
            "type": "dotnet",
            "task": "build",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/RegistrationWebAPI"
            }
        }
    ]
}
